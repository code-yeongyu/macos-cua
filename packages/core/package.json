{
	"name": "@macos-cua/core",
	"version": "0.1.0",
	"type": "module",
	"description": "Platform-abstracted computer-use interfaces",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "pnpm run build:native && tsgo",
		"build:ts": "tsgo",
		"build:native": "./native/build.sh",
		"typecheck": "tsgo --noEmit",
		"test": "vitest --run --root ../.. $(find ../../packages/core -name '*.test.ts' | sort)"
	},
	"files": ["dist", "native/sckit.m", "native/build.sh", "native/libsckit.dylib"],
	"dependencies": {
		"esbuild": "^0.25.0",
		"get-windows": "9.3.0",
		"isolated-vm": "^6.0.2",
		"koffi": "2.16.2",
		"node-mac-permissions": "2.5.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"vitest": "^2.1.0",
		"@types/node": "^22.0.0"
	}
}
