{
	"name": "@macos-cua/pi-extension",
	"version": "0.1.0",
	"type": "module",
	"description": "Pi coding agent extension for macOS computer control",
	"keywords": ["pi-extension", "pi-mono", "macos", "computer-use"],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"pi": {
		"extensions": ["./src/index.ts"]
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsgo",
		"typecheck": "tsgo --noEmit",
		"test": "vitest --run"
	},
	"dependencies": {
		"@macos-cua/core": "workspace:*",
		"@mariozechner/pi-ai": "^0.73.1",
		"typebox": "1.1.38"
	},
	"devDependencies": {
		"typescript": "^5.7.0",

		"vitest": "^2.1.0",
		"@types/node": "^20.0.0"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "^0.73.1"
	}
}
